---
const {
    href = '#',
    variant = 'primary',
    class: className = '',
} = Astro.props;

const variants = {
    primary: 'bg-accent text-black hover:opacity-90',
    secondary: 'border border-gray-700 hover:border-accent hover:text-accent',
};
---

<a
        href={href}
        class={`inline-flex items-center justify-center rounded-xl px-6 py-3 font-semibold transition ${variants[variant]} ${className}`}
>
    <slot />
</a>