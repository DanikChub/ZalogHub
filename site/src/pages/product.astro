---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout>
    <Header />

    <main>
        <!-- HERO -->
        <section class="pt-32 pb-24 px-6 lg:px-20 relative overflow-hidden">
            <div class="absolute left-[-120px] top-[-50px] w-[520px] h-[520px] bg-accent/15 blur-[140px] rounded-full"></div>
            <div class="absolute right-[8%] top-[15%] w-[420px] h-[240px] bg-accent/10 blur-[120px] rounded-full"></div>

            <div class="container-main relative z-10">
                <div class="grid lg:grid-cols-2 gap-16 items-center">
                    <div class="max-w-2xl">
                        <div class="inline-flex items-center gap-2 rounded-full border border-accent/20 bg-accent/5 px-4 py-2 text-sm text-gray-300 mb-6">
                            <span class="w-2 h-2 rounded-full bg-accent"></span>
                            Продукт в разработке
                        </div>

                        <h1 class="text-5xl lg:text-7xl font-black leading-tight">
                            Единая инфраструктура<br>
                            для рынка <span class="text-accent">займов под залог</span>
                        </h1>

                        <p class="mt-6 text-lg text-gray-400 max-w-xl leading-relaxed">
                            ZalogHub создаётся как центральная платформа для брокеров, инвесторов и владельцев брокерских команд.
                            Вместо хаоса чатов — понятная система публикации кейсов, фильтрации, аналитики, сопровождения и ведения сделок.
                        </p>

                        <div class="mt-8 flex flex-wrap gap-4">
                            <a href="investors.html" class="bg-accent text-black px-6 py-3 rounded-xl font-semibold hover:opacity-90 transition">
                                Для инвесторов
                            </a>
                            <a href="features.html" class="border border-gray-700 px-6 py-3 rounded-xl hover:border-accent hover:text-accent transition">
                                Смотреть возможности
                            </a>
                        </div>
                    </div>

                    <div class="relative">
                        <div class="absolute inset-0 bg-accent/10 blur-[100px] rounded-full"></div>

                        <div class="relative border border-white/10 rounded-[32px] bg-[#0B0B0B]/90 p-8 lg:p-10 shadow-2xl">
                            <div class="flex items-center justify-between border-b border-white/10 pb-5">
                                <div>
                                    <div class="text-sm text-gray-500">Будущая экосистема</div>
                                    <div class="text-2xl font-bold mt-1">ZalogHub Platform</div>
                                </div>
                                <div class="px-3 py-1 rounded-full text-xs border border-accent/20 bg-accent/10 text-accent">
                                    roadmap
                                </div>
                            </div>

                            <div class="grid sm:grid-cols-2 gap-4 mt-6">
                                <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
                                    <div class="text-sm text-gray-500">Инвесторы</div>
                                    <div class="text-lg font-semibold mt-2">Поиск и фильтрация кейсов</div>
                                </div>

                                <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
                                    <div class="text-sm text-gray-500">Брокеры</div>
                                    <div class="text-lg font-semibold mt-2">Публикация и передача заявок</div>
                                </div>

                                <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
                                    <div class="text-sm text-gray-500">Руководители</div>
                                    <div class="text-lg font-semibold mt-2">Статистика и контроль команды</div>
                                </div>

                                <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-5">
                                    <div class="text-sm text-gray-500">Сопровождение</div>
                                    <div class="text-lg font-semibold mt-2">Юр. поддержка и договоры</div>
                                </div>
                            </div>

                            <div class="mt-6 rounded-2xl border border-accent/20 bg-accent/5 p-5">
                                <div class="text-sm text-gray-400">Ключевая идея</div>
                                <div class="text-xl font-bold mt-2">
                                    Сделать рынок не просто удобнее, а управляемым.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- WHAT PRODUCT IS -->
        <section class="py-20 px-6 lg:px-20 border-t border-gray-900">
            <div class="container-main">
                <div class="grid lg:grid-cols-2 gap-12 items-start">
                    <div>
                        <h2 class="text-3xl lg:text-4xl font-bold mb-6">Что такое ZalogHub</h2>
                        <p class="text-gray-400 leading-relaxed text-lg">
                            Это не просто ещё один каталог заявок. ZalogHub задуман как инфраструктурный слой рынка:
                            место, где формируется поток кейсов, строится работа брокеров, подключается инвестор,
                            а сама сделка получает прозрачную структуру и сопровождение.
                        </p>
                    </div>

                    <div class="grid gap-4">
                        <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-6">
                            <div class="text-xl font-semibold mb-2">Единый поток кейсов</div>
                            <p class="text-gray-400">Без бесконечных пересылок, потерь сообщений и ручного хаоса.</p>
                        </div>

                        <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-6">
                            <div class="text-xl font-semibold mb-2">Инфраструктура сделки</div>
                            <p class="text-gray-400">От публикации заявки до сопровождения и фиксации результата.</p>
                        </div>

                        <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-6">
                            <div class="text-xl font-semibold mb-2">Роль для каждого участника</div>
                            <p class="text-gray-400">Брокер, инвестор, владелец команды — каждый видит свой контур работы.</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- AUDIENCES -->
        <section class="py-20 px-6 lg:px-20 border-t border-gray-900">
            <div class="container-main">
                <h2 class="text-3xl lg:text-4xl font-bold mb-10">Кому нужен продукт</h2>

                <div class="grid lg:grid-cols-3 gap-6">
                    <div class="rounded-3xl border border-white/10 bg-[#0D0D0D] p-8">
                        <div class="text-accent text-sm mb-3">01</div>
                        <h3 class="text-2xl font-bold mb-4">Инвесторам</h3>
                        <p class="text-gray-400 leading-relaxed">
                            Чтобы быстро находить релевантные кейсы, не теряться в потоках сообщений,
                            работать через фильтры, поиск и понятную структуру заявок.
                        </p>
                    </div>

                    <div class="rounded-3xl border border-white/10 bg-[#0D0D0D] p-8">
                        <div class="text-accent text-sm mb-3">02</div>
                        <h3 class="text-2xl font-bold mb-4">Брокерам</h3>
                        <p class="text-gray-400 leading-relaxed">
                            Чтобы публиковать заявки профессионально, быстрее передавать кейсы инвесторам
                            и работать в более серьезной среде, чем мессенджеры.
                        </p>
                    </div>

                    <div class="rounded-3xl border border-white/10 bg-[#0D0D0D] p-8">
                        <div class="text-accent text-sm mb-3">03</div>
                        <h3 class="text-2xl font-bold mb-4">Владельцам команд</h3>
                        <p class="text-gray-400 leading-relaxed">
                            Чтобы видеть статистику продаж брокеров, понимать эффективность,
                            контролировать воронку и строить управляемую брокерскую систему.
                        </p>
                    </div>
                </div>
            </div>
        </section>

        <!-- PRODUCT BLOCKS -->
        <section class="py-20 px-6 lg:px-20 border-t border-gray-900">
            <div class="container-main">
                <h2 class="text-3xl lg:text-4xl font-bold mb-10">Из чего будет состоять платформа</h2>

                <div class="grid md:grid-cols-2 xl:grid-cols-4 gap-6">
                    <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-6">
                        <div class="text-xl font-semibold mb-3">Лента кейсов</div>
                        <p class="text-gray-400">Структурированный поток заявок вместо чатов и пересланных сообщений.</p>
                    </div>

                    <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-6">
                        <div class="text-xl font-semibold mb-3">Фильтрация и поиск</div>
                        <p class="text-gray-400">Быстрый доступ к кейсам по параметрам недвижимости, сумме и условиям.</p>
                    </div>

                    <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-6">
                        <div class="text-xl font-semibold mb-3">Аналитика брокеров</div>
                        <p class="text-gray-400">Показатели команды, эффективность продаж и прозрачность результатов.</p>
                    </div>

                    <div class="rounded-2xl border border-gray-800 bg-gray-900/60 p-6">
                        <div class="text-xl font-semibold mb-3">Сопровождение сделки</div>
                        <p class="text-gray-400">Поддержка инвестора, работа с документами и помощь в оформлении.</p>
                    </div>
                </div>
            </div>
        </section>

        <!-- LEGAL -->
        <section class="py-20 px-6 lg:px-20 border-t border-gray-900">
            <div class="container-main">
                <div class="rounded-[32px] border border-accent/20 bg-gradient-to-br from-accent/10 to-transparent p-10 lg:p-14">
                    <div class="grid lg:grid-cols-2 gap-10 items-start">
                        <div>
                            <div class="text-accent text-sm font-medium mb-4">Юридический контур</div>
                            <h2 class="text-3xl lg:text-4xl font-bold mb-5">Не просто заявки, а опора на сопровождение</h2>
                            <p class="text-gray-300 leading-relaxed text-lg">
                                Вокруг ZalogHub закладывается не только технологическая, но и практическая база:
                                юридическая поддержка, помощь в подготовке договоров, сопровождение логики сделки и снижение операционного хаоса.
                            </p>
                        </div>

                        <div class="grid gap-4">
                            <div class="rounded-2xl border border-white/10 bg-black/30 p-5">
                                <div class="font-semibold mb-2">Помощь с договорной частью</div>
                                <p class="text-gray-400">Подготовка и структурирование документов под реальные сделки.</p>
                            </div>
                            <div class="rounded-2xl border border-white/10 bg-black/30 p-5">
                                <div class="font-semibold mb-2">Юридическая поддержка</div>
                                <p class="text-gray-400">Важный слой доверия для инвестора и участников процесса.</p>
                            </div>
                            <div class="rounded-2xl border border-white/10 bg-black/30 p-5">
                                <div class="font-semibold mb-2">Ведение сделки</div>
                                <p class="text-gray-400">Не просто найти кейс, а довести работу до результата.</p>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <!-- STATUS -->
        <section class="py-20 px-6 lg:px-20 border-t border-gray-900">
            <div class="container-main">
                <div class="max-w-3xl">
                    <h2 class="text-3xl lg:text-4xl font-bold mb-6">Текущий статус</h2>
                    <p class="text-gray-400 text-lg leading-relaxed">
                        Платформа находится на этапе формирования продукта и бренда. Сейчас задача сайта —
                        зафиксировать позиционирование, показать серьезность намерений и собрать ранний интерес со стороны инвесторов,
                        брокеров и партнеров до запуска полноценного сервиса.
                    </p>
                </div>
            </div>
        </section>

        <!-- CTA -->
        <section class="py-28 px-6 lg:px-20 border-t border-gray-900 text-center">
            <div class="container-main">
                <h2 class="text-4xl lg:text-5xl font-black mb-6">
                    Мы строим новый стандарт рынка
                </h2>
                <p class="text-gray-400 text-lg max-w-2xl mx-auto mb-8">
                    Если вы инвестор, брокер или владелец команды — ZalogHub можно обсуждать уже сейчас.
                </p>
                <a href="contacts.html" class="inline-flex bg-accent text-black px-8 py-4 rounded-xl text-lg font-semibold hover:opacity-90 transition">
                    Обсудить сотрудничество
                </a>
            </div>
        </section>
    </main>

    <Footer/>
</BaseLayout>